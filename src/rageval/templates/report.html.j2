<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ result.suite_name }} report</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <style>
      :root {
        --blue: #1d57c8;
        --blue-soft: #eef5ff;
        --purple: #6d35b7;
        --red: #d23c3c;
        --green: #1f9d55;
        --amber: #d98300;
        --gray: #7b8494;
        --ink: #172033;
        --muted: #637083;
        --line: #dbe3ef;
        --soft: #f7f9fc;
        --soft-red: #fff2f2;
        --soft-green: #edf9f1;
        --soft-amber: #fff7e8;
      }
      body {
        margin: 0;
        padding: 0.9rem 0;
        color: var(--ink);
        background: #eef6ff;
        font-size: 14px;
      }
      main.container { max-width: 1480px; }
      h1 { margin: 0; color: #071a3d; font-size: 2rem; letter-spacing: 0; }
      h2 { margin: 0 0 0.75rem; color: #0d3d8f; font-size: 1.05rem; }
      h3 { margin: 0; font-size: 0.95rem; }
      p { line-height: 1.5; }
      table { font-size: 0.88rem; }
      code, pre { font-size: 0.82rem; }
      pre { white-space: pre-wrap; word-break: break-word; }
      .muted { color: var(--muted); }
      .topbar {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 1rem;
        align-items: start;
        margin-bottom: 1rem;
      }
      .subtitle { margin: 0.25rem 0 0; color: var(--muted); font-size: 1rem; }
      .status-strip { display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: flex-end; }
      .status-card {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.55rem;
        min-width: 9.4rem;
        padding: 0.6rem 0.75rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #fff;
      }
      .status-card strong { display: block; font-size: 1rem; }
      .status-card span:last-child { display: block; color: var(--muted); font-size: 0.74rem; }
      .status-icon {
        display: inline-flex;
        width: 1.9rem;
        height: 1.9rem;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-weight: 800;
      }
      .status-ok { color: var(--green); background: var(--soft-green); border: 1px solid #b9e5c8; }
      .status-warn { color: var(--amber); background: var(--soft-amber); border: 1px solid #f1d194; }
      .status-err { color: var(--red); background: var(--soft-red); border: 1px solid #f2b8b8; }
      .status-info { color: var(--blue); background: var(--blue-soft); border: 1px solid #c7dafb; }
      .panel {
        margin: 0 0 1rem;
        padding: 1rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #fff;
      }
      .executive {
        background: linear-gradient(0deg, #fff, #fff), var(--blue-soft);
        border-color: #c8dcfb;
      }
      .executive p { margin: 0.35rem 0; }
      .cards-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
        margin-bottom: 1rem;
      }
      .metric-card {
        padding: 0.9rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #fff;
      }
      .metric-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.8rem;
      }
      .family-title { display: flex; gap: 0.5rem; align-items: center; font-weight: 800; }
      .family-blue { color: var(--blue); }
      .family-purple { color: var(--purple); }
      .family-red { color: var(--red); }
      .family-gray { color: var(--gray); }
      .css-icon {
        display: inline-flex;
        width: 1.45rem;
        height: 1.45rem;
        align-items: center;
        justify-content: center;
        border: 2px solid currentColor;
        border-radius: 50%;
        font-size: 0.8rem;
        line-height: 1;
      }
      .metric-mini-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
        border: 1px solid var(--line);
        border-radius: 8px;
        overflow: hidden;
      }
      .metric-mini {
        min-height: 6.1rem;
        padding: 0.8rem 0.6rem;
        text-align: center;
        border-right: 1px solid var(--line);
      }
      .metric-mini:last-child { border-right: 0; }
      .metric-mini .name { margin-bottom: 0.55rem; color: #273348; font-size: 0.82rem; }
      .metric-mini .value { display: block; font-size: 1.55rem; font-weight: 800; }
      .metric-mini .subtext { display: block; color: var(--muted); font-size: 0.82rem; }
      .score-good { color: var(--green); }
      .score-mid { color: var(--amber); }
      .score-low { color: var(--red); }
      .score-na { color: var(--gray); }
      .metric-hint { margin: 0.55rem 0 0; color: var(--muted); font-size: 0.78rem; text-align: center; }
      .analytics-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
        gap: 1rem;
      }
      .chart-stack { display: grid; gap: 1rem; }
      .info-dot {
        display: inline-flex;
        width: 1rem;
        height: 1rem;
        align-items: center;
        justify-content: center;
        border: 1px solid #aab4c3;
        border-radius: 50%;
        color: #718096;
        font-size: 0.7rem;
      }
      .heatmap-wrap, .table-wrap { overflow-x: auto; }
      .heatmap th, .heatmap td { vertical-align: middle; }
      .heatmap td:first-child { font-weight: 700; }
      .heat-cell {
        display: block;
        min-width: 7.8rem;
        padding: 0.7rem 0.5rem;
        text-align: center;
        border-radius: 4px;
      }
      .heat-cell strong { display: block; font-size: 1rem; }
      .heat-good { background: #e9f7ed; color: #16713c; }
      .heat-mid { background: #fff4d9; color: #a45e00; }
      .heat-low { background: #fde7e7; color: #b42318; }
      .heat-na { background: #f1f4f8; color: #778293; }
      .heat-legend {
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
        margin-top: 0.7rem;
        color: var(--muted);
        font-size: 0.78rem;
      }
      .legend-swatch {
        display: inline-block;
        width: 0.9rem;
        height: 0.9rem;
        margin-right: 0.25rem;
        border-radius: 2px;
        vertical-align: -0.15rem;
      }
      .swatch-good { background: #bde6c8; }
      .swatch-mid { background: #ffe0a3; }
      .swatch-low { background: #f6b5b5; }
      .swatch-na { background: #d9dee6; }
      .findings-list { display: grid; gap: 0; border: 1px solid var(--line); border-radius: 8px; overflow: hidden; }
      .finding-row {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 0.85rem;
        align-items: center;
        padding: 0.85rem 1rem;
        border-bottom: 1px solid var(--line);
      }
      .finding-row:last-child { border-bottom: 0; }
      .finding-icon {
        display: inline-flex;
        width: 1.9rem;
        height: 1.9rem;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        color: #fff;
        font-weight: 800;
      }
      .finding-icon.ok { background: var(--green); }
      .finding-icon.warn { background: var(--amber); }
      .finding-icon.err { background: var(--red); }
      .finding-title { margin: 0; font-weight: 800; }
      .finding-desc { margin: 0.1rem 0 0; color: var(--muted); }
      .pill {
        display: inline-block;
        padding: 0.22rem 0.55rem;
        border-radius: 6px;
        border: 1px solid var(--line);
        color: #344054;
        background: #f8fafc;
        font-size: 0.78rem;
        font-weight: 700;
      }
      .pill.ok { color: #16713c; background: #eef9f1; border-color: #bde6c8; }
      .pill.warn { color: #a45e00; background: #fff7e8; border-color: #f2cf91; }
      .pill.err { color: #b42318; background: #fff1f1; border-color: #f2b8b8; }
      .run-meta {
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
        margin-top: 0.55rem;
      }
      .evidence-meta {
        display: flex;
        gap: 0.35rem;
        flex-wrap: wrap;
        margin-top: 0.25rem;
      }
      .case-toolbar {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
        margin-bottom: 0.5rem;
      }
      .case-toolbar input, .case-toolbar select { max-width: 13rem; height: 2.25rem; margin: 0; }
      .case-index tbody tr.row-warn { background: #fffafa; }
      .case-index tbody tr.row-ok { background: #f8fffa; }
      .score-chip { display: inline-block; margin: 0 0.45rem 0.25rem 0; white-space: nowrap; }
      .score-dot {
        display: inline-block;
        width: 0.38rem;
        height: 0.38rem;
        margin-left: 0.25rem;
        border-radius: 50%;
        vertical-align: middle;
      }
      .dot-good { background: var(--green); }
      .dot-mid { background: var(--amber); }
      .dot-low { background: var(--red); }
      .dot-na { background: #aab4c3; }
      .case-card {
        margin-top: 0.75rem;
        padding: 0;
        border: 1px solid #ffc8c8;
        border-radius: 8px;
        background: #fffafa;
        overflow: hidden;
      }
      .case-card > summary {
        display: flex;
        gap: 0.55rem;
        align-items: center;
        padding: 0.75rem 1rem;
        list-style: none;
        cursor: pointer;
      }
      .case-card > summary::-webkit-details-marker { display: none; }
      .case-id { color: #1d4fac; font-weight: 800; }
      .summary-spacer { flex: 1; }
      .case-body { padding: 0 1rem 1rem; }
      .drill-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.8rem;
      }
      .drill-panel {
        min-height: 8.5rem;
        padding: 0.75rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #fff;
      }
      .drill-panel h4 {
        margin: 0 0 0.5rem;
        font-size: 0.9rem;
      }
      .answer-panel { grid-column: span 1; }
      .retrieved-list { margin: 0; padding-left: 1.1rem; }
      .retrieved-list li { margin-bottom: 0.5rem; }
      .metric-card-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
        gap: 0.55rem;
        margin-top: 0.85rem;
      }
      .metric-result-tile {
        padding: 0.65rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #fff;
        text-align: center;
      }
      .metric-result-tile .value { display: block; font-size: 1.2rem; font-weight: 800; }
      details.raw-details { margin-top: 0.4rem; }
      details.raw-details summary { color: var(--muted); cursor: pointer; font-size: 0.82rem; }
      .footnotes { color: var(--muted); font-size: 0.82rem; }
      @media (max-width: 980px) {
        .topbar, .analytics-grid, .drill-grid { grid-template-columns: 1fr; }
        .cards-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .status-strip, .case-toolbar { justify-content: flex-start; }
      }
      @media (max-width: 640px) {
        .cards-grid { grid-template-columns: 1fr; }
        .case-toolbar { display: block; }
        .case-toolbar input, .case-toolbar select { max-width: none; margin-bottom: 0.5rem; }
      }
    </style>
  </head>
  <body>
    <main class="container">
      <header class="topbar">
        <div>
          <h1>{{ result.suite_name }} Report</h1>
          <p class="subtitle">
            {{ run_metadata.run_mode_label }} · {{ result.system_name }} · {{ diagnostics.total_cases }} cases ·
            {{ result.run_at.date().isoformat() }}
          </p>
          <div class="run-meta" aria-label="Run metadata">
            <span class="pill">{{ run_metadata.run_mode_label }}</span>
            {% if run_metadata.no_cache is not none %}
              <span class="pill {% if run_metadata.no_cache %}warn{% else %}ok{% endif %}">
                Cache {% if run_metadata.no_cache %}bypassed{% else %}enabled{% endif %}
              </span>
            {% endif %}
            {% if run_metadata.metrics_selected %}
              <span class="pill">Metrics: {{ run_metadata.metrics_selected|join(", ") }}</span>
            {% endif %}
          </div>
        </div>
        <div class="status-strip">
          <div class="status-card">
            <span class="status-icon {% if diagnostics.overall_errors == 0 %}status-ok{% else %}status-err{% endif %}">✓</span>
            <span><strong>{{ diagnostics.overall_errors }}</strong>Overall Errors</span>
          </div>
          <div class="status-card">
            <span class="status-icon {% if diagnostics.metric_errors == 0 %}status-ok{% else %}status-err{% endif %}">✓</span>
            <span><strong>{{ diagnostics.metric_errors }}</strong>Metric Errors</span>
          </div>
          <div class="status-card">
            <span class="status-icon status-info">$</span>
            <span><strong>{{ result.total_cost_usd|money }}</strong>Cost (USD)</span>
          </div>
          <div class="status-card">
            <span class="status-icon status-info">◷</span>
            <span><strong>{{ result.total_duration_seconds|seconds }}</strong>Duration</span>
          </div>
        </div>
      </header>

      <section class="panel executive">
        <h2>Executive Summary</h2>
        <p>{{ run_summary }}</p>
        {% for line in executive_summary_lines %}
          <p>{{ line }}</p>
        {% endfor %}
      </section>

      <section class="cards-grid" aria-label="Metric summary cards">
        {% for card in metric_scorecards %}
          <article class="metric-card">
            <div class="metric-card-header">
              <div class="family-title family-{{ card.accent }}">
                <span class="css-icon">
                  {% if card.icon == "search" %}⌕{% elif card.icon == "database" %}▤{% elif card.icon == "shield" %}◇{% else %}◷{% endif %}
                </span>
                {{ card.family }}
              </div>
              <span class="info-dot">i</span>
            </div>
            <div class="metric-mini-grid">
              {% for metric in card.metrics %}
                <div class="metric-mini">
                  <div class="name">{{ metric.metric_name }}</div>
                  <span class="value {% if metric.score is not none %}{{ metric.score|score_class }}{% else %}score-na{% endif %}">
                    {{ metric.label }}
                  </span>
                  <span class="subtext">{{ metric.subtext }}</span>
                </div>
              {% endfor %}
            </div>
            <p class="metric-hint">{{ card.hint }}</p>
          </article>
        {% endfor %}
      </section>

      <section class="analytics-grid">
        <article class="panel">
          <h2>Per-Category Metric Heatmap <span class="muted">(score)</span> <span class="info-dot">i</span></h2>
          <div class="heatmap-wrap">
            <table class="heatmap">
              <thead>
                <tr>
                  <th>Category</th>
                  {% for metric_name in category_breakdown.metric_names %}
                    <th>{{ metric_name }}</th>
                  {% endfor %}
                </tr>
              </thead>
              <tbody>
                {% for row in category_breakdown.rows %}
                  <tr>
                    <td>
                      {{ row.label }}<br>
                      <span class="muted">(n = {{ row.case_count }})</span>
                    </td>
                    {% for cell in row.cells %}
                      <td>
                        {% if cell.mean is not none %}
                          <span class="heat-cell heat-{{ cell.mean|score_class|replace('score-', '') }}">
                            <strong>{{ "%.3f"|format(cell.mean) }}</strong>
                            <span>{{ cell.n }} / {{ row.case_count }}</span>
                          </span>
                        {% else %}
                          <span class="heat-cell heat-na">
                            <strong>—</strong>
                            <span>n/a</span>
                          </span>
                        {% endif %}
                      </td>
                    {% endfor %}
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          <div class="heat-legend">
            <span><span class="legend-swatch swatch-good"></span>≥ 0.80 (Good)</span>
            <span><span class="legend-swatch swatch-mid"></span>0.50–0.79 (Fair)</span>
            <span><span class="legend-swatch swatch-low"></span>&lt; 0.50 (Poor)</span>
            <span><span class="legend-swatch swatch-na"></span>Not applicable</span>
          </div>
        </article>

        <div class="chart-stack">
          <article class="panel">
            <h2>Route Distribution <span class="muted">(n = {{ diagnostics.total_cases }})</span> <span class="info-dot">i</span></h2>
            <canvas id="route-chart" height="175"></canvas>
          </article>
          <article class="panel">
            <h2>Metric Coverage <span class="info-dot">i</span></h2>
            <canvas id="coverage-chart" height="175"></canvas>
            <p class="muted">Coverage is out of {{ diagnostics.total_cases }} total cases.</p>
          </article>
          <article class="panel" style="display:none">
            <canvas id="aggregate-chart" height="120"></canvas>
          </article>
        </div>
      </section>

      <section class="panel">
        <h2>Notable Findings <span class="info-dot">i</span></h2>
        <div class="findings-list">
          {% if result.errors %}
            <div class="finding-row">
              <span class="finding-icon err">×</span>
              <div>
                <p class="finding-title">Overall errors</p>
                <p class="finding-desc">
                  {% for error in result.errors %}
                    {{ error }}{% if not loop.last %}; {% endif %}
                  {% endfor %}
                </p>
              </div>
              <span class="pill err">
                {{ result.errors|length }} {% if result.errors|length == 1 %}error{% else %}errors{% endif %}
              </span>
            </div>
          {% endif %}
          {% for finding in finding_cards %}
            <div class="finding-row">
              <span class="finding-icon {{ finding.status }}">{{ finding.icon }}</span>
              <div>
                <p class="finding-title">{{ finding.title }}</p>
                <p class="finding-desc">{{ finding.description }}</p>
              </div>
              <span class="pill {{ finding.status }}">
                {{ finding.count }} {% if finding.count == 1 %}case{% else %}cases{% endif %}
              </span>
            </div>
          {% endfor %}
        </div>
        {% if not notable_findings %}
          <p class="muted">No highlighted findings.</p>
        {% else %}
          <details class="raw-details">
            <summary>Show finding details</summary>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Group</th>
                    <th>Case</th>
                    <th>Metric</th>
                    <th>Explanation</th>
                  </tr>
                </thead>
                <tbody>
                  {% for group in notable_findings %}
                    {% for issue in group.issues %}
                      <tr>
                        <td>{{ group.group }}</td>
                        <td>{{ issue.case_id }}</td>
                        <td>{{ issue.metric_name|default("—", true) }}</td>
                        <td>{{ issue.explanation }}</td>
                      </tr>
                    {% endfor %}
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </details>
        {% endif %}
      </section>

      <section class="panel">
        <h2>Case Browser <span class="muted">({{ diagnostics.total_cases }} cases)</span></h2>
        <div class="case-toolbar">
          <input id="case-search" type="search" placeholder="Search cases...">
          <select id="case-type-filter" aria-label="Filter by type">
            <option value="">All Types</option>
            {% for row in category_breakdown.rows %}
              <option value="{{ row.category }}">{{ row.label }}</option>
            {% endfor %}
          </select>
          <select id="case-route-filter" aria-label="Filter by route">
            <option value="">All Routes</option>
            {% for route in route_distribution %}
              <option value="{{ route.key }}">{{ route.display_label }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="table-wrap">
          <table class="case-index">
            <thead>
              <tr>
                <th>Case</th>
                <th>Type</th>
                <th>Route</th>
                <th>Key Scores</th>
                <th>Flags</th>
              </tr>
            </thead>
            <tbody>
              {% for row in case_index_rows %}
                <tr
                  class="{% if row.error_count or row.skip_count %}row-warn{% else %}row-ok{% endif %}"
                  data-case-row
                  data-case-id="{{ row.case_id }}"
                  data-question="{{ row.question }}"
                  data-type="{{ row.category_key }}"
                  data-route="{{ row.route_key }}"
                >
                  <td><a href="#case-{{ row.case_id }}">{{ row.case_id }}</a></td>
                  <td>{{ row.category_label }}</td>
                  <td>{{ row.route_label }}</td>
                  <td>
                    {% for score in row.key_scores %}
                      <span class="score-chip">
                        {{ score.metric_name }}
                        {% if score.skipped or score.missing or score.value is none %}
                          <span class="muted">—</span>
                        {% elif score.error %}
                          <span class="score-low">error</span>
                        {% else %}
                          <span class="{{ score.value|score_class }}">
                            {{ "%.3f"|format(score.value) }}
                          </span>
                          <span class="score-dot dot-{{ score.value|score_class|replace('score-', '') }}"></span>
                        {% endif %}
                      </span>
                    {% endfor %}
                  </td>
                  <td>
                    {% for flag in row.flags %}
                      <span class="pill {{ flag.status }}">{{ flag.label }}</span>
                    {% endfor %}
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

        {% for case_result in result.case_results %}
          {% set route_decision = case_result.response.routing_decision %}
          {% set route_key = route_decision|route_key %}
          {% set type_key = case_result.question_type.value if case_result.question_type else "missing" %}
          {% set case_metric_errors = case_result.metric_results | selectattr("error") | list | length %}
          <details id="case-{{ case_result.case_id }}" class="case-card"{% if loop.first %} open{% endif %}>
            <summary>
              <span>⌄</span>
              <span class="case-id">{{ case_result.case_id }}</span>
              <span class="pill">{{ type_key|route_label }}</span>
              <span class="pill">{{ route_decision|route_display_label }}</span>
              {% if case_metric_errors > 0 %}
                <span class="pill err">Metric error</span>
              {% elif case_result.response.refused %}
                <span class="pill ok">Correct refusal</span>
              {% endif %}
              <span class="summary-spacer"></span>
              <a href="#case-{{ case_result.case_id }}">View full case ↗</a>
              <span class="muted">×</span>
            </summary>
            <div class="case-body">
              <div class="drill-grid">
                <div class="drill-panel">
                  <h4>Question</h4>
                  <p>{{ case_result.question }}</p>
                </div>
                <div class="drill-panel answer-panel">
                  <h4>Answer (model)</h4>
                  <p>{{ case_result.response.answer }}</p>
                </div>
                <div class="drill-panel">
                  <h4>SQL Evidence</h4>
                  {% if case_result.response.sql_result %}
                    <pre><code>{{ case_result.response.sql_result.query }}</code></pre>
                    {% if case_result.response.sql_result.error %}
                      <p class="score-low">{{ case_result.response.sql_result.error }}</p>
                    {% else %}
                      <p class="score-good">✓ SQL executed successfully</p>
                    {% endif %}
                    <details class="raw-details">
                      <summary>Show result rows</summary>
                      <pre>{{ case_result.response.sql_result.rows|json_pretty }}</pre>
                    </details>
                  {% else %}
                    <p class="muted">No SQL evidence for this case.</p>
                  {% endif %}
                </div>
                <div class="drill-panel">
                  <h4>Retrieved Evidence</h4>
                  {% if case_result.response.retrieved_docs %}
                    <ol class="retrieved-list">
                      {% for doc in case_result.response.retrieved_docs[:3] %}
                        <li>
                          <strong>{{ doc.metadata.title|default(doc.id) }}</strong><br>
                          <span class="muted">{{ doc.content|short(120) }}</span>
                          <div class="evidence-meta">
                            {% if doc.metadata.retrieval_mode %}
                              <span class="pill">{{ doc.metadata.retrieval_mode }}</span>
                            {% endif %}
                            {% if doc.metadata.score is number %}
                              <span class="pill">score {{ "%.3f"|format(doc.metadata.score) }}</span>
                            {% endif %}
                            {% if doc.metadata.distance is number %}
                              <span class="pill">distance {{ "%.3f"|format(doc.metadata.distance) }}</span>
                            {% endif %}
                            {% if doc.metadata.embedding_model %}
                              <span class="pill">{{ doc.metadata.embedding_model }}</span>
                            {% endif %}
                          </div>
                        </li>
                      {% endfor %}
                    </ol>
                  {% else %}
                    <p class="muted">No retrieved documents for this case.</p>
                  {% endif %}
                </div>
              </div>

              <h4 style="margin-top: 0.9rem;">Metric Results</h4>
              <div class="metric-card-row">
                {% for metric in case_result.metric_results %}
                  <div class="metric-result-tile">
                    <div>{{ metric.metric_name }}</div>
                    {% if metric.details.skipped %}
                      <span class="value score-na">—</span>
                      <span class="muted">skipped</span>
                    {% elif metric.value is none %}
                      <span class="value score-na">—</span>
                      <span class="muted">n/a</span>
                    {% else %}
                      <span class="value {{ metric.value|score_class }}">{{ "%.3f"|format(metric.value) }}</span>
                      <span class="muted">{{ metric.value|score_word|title }}</span>
                    {% endif %}
                    {% if metric.error %}
                      <p class="score-low">{{ metric.error }}</p>
                    {% endif %}
                    <details class="raw-details">
                      <summary>Show details</summary>
                      <pre>{{ metric.details|json_pretty }}</pre>
                    </details>
                  </div>
                {% endfor %}
              </div>
            </div>
          </details>
        {% endfor %}
      </section>

      <section class="panel footnotes">
        <h2>Methodology Notes</h2>
        <ul>
          <li>Generated reports load styling and charts from Pico.css and Chart.js CDNs.</li>
          <li>Tables remain readable if JavaScript is disabled.</li>
          <li>Prefix retrieval metrics evaluate article-level IDs before <code>#</code>.</li>
          <li>Skipped cases are not failures; they indicate a metric is not applicable.</li>
          <li>Unanswerable / Adversarial cases are displayed as refusal routes when routed correctly.</li>
        </ul>
      </section>
    </main>

    {% if metric_summaries %}
      <script id="rageval-metric-data" type="application/json">
        {{ {
          "labels": metric_summaries|map(attribute="metric_name")|list,
          "scores": metric_summaries|map(attribute="score")|list,
          "successful": coverage_data|map(attribute="successful")|list,
          "errors": coverage_data|map(attribute="errors")|list,
          "skipped": coverage_data|map(attribute="skipped")|list
        }|tojson }}
      </script>
      <script id="rageval-route-data" type="application/json">
        {{ {
          "labels": route_distribution|map(attribute="display_label")|list,
          "keys": route_distribution|map(attribute="key")|list,
          "counts": route_distribution|map(attribute="count")|list,
          "percents": route_distribution|map(attribute="percent")|list
        }|tojson }}
      </script>
      <script>
        (function () {
          var rows = Array.prototype.slice.call(document.querySelectorAll(".case-index tbody tr"));
          var search = document.getElementById("case-search");
          var typeFilter = document.getElementById("case-type-filter");
          var routeFilter = document.getElementById("case-route-filter");

          function applyCaseFilters() {
            var q = (search && search.value || "").toLowerCase();
            var type = typeFilter && typeFilter.value || "";
            var route = routeFilter && routeFilter.value || "";
            rows.forEach(function (row) {
              var haystack = ((row.dataset.caseId || "") + " " + (row.dataset.question || "")).toLowerCase();
              var typeOk = !type || row.dataset.type === type;
              var routeOk = !route || row.dataset.route === route;
              var searchOk = !q || haystack.indexOf(q) !== -1;
              row.style.display = typeOk && routeOk && searchOk ? "" : "none";
            });
          }
          if (search) search.addEventListener("input", applyCaseFilters);
          if (typeFilter) typeFilter.addEventListener("change", applyCaseFilters);
          if (routeFilter) routeFilter.addEventListener("change", applyCaseFilters);

          if (typeof Chart === "undefined") return;
          var metricNode = document.getElementById("rageval-metric-data");
          var routeNode = document.getElementById("rageval-route-data");
          var metricData = metricNode ? JSON.parse(metricNode.textContent) : null;
          var routeData = routeNode ? JSON.parse(routeNode.textContent) : null;
          var routeColors = {
            factual: "#8b6ee8",
            analytical: "#2fa65a",
            hybrid: "#5da0f0",
            unanswerable: "#ef5350",
            missing: "#b42318"
          };

          if (metricData && document.getElementById("aggregate-chart")) {
            new Chart(document.getElementById("aggregate-chart"), {
              type: "bar",
              data: {
                labels: metricData.labels,
                datasets: [{ label: "Score", data: metricData.scores, backgroundColor: "#1d57c8" }]
              },
              options: {
                indexAxis: "y",
                scales: { x: { min: 0, max: 1 } },
                plugins: { legend: { display: false } }
              }
            });
          }

          if (routeData && document.getElementById("route-chart")) {
            var bg = (routeData.keys || []).map(function (k) { return routeColors[k] || "#8a8f98"; });
            new Chart(document.getElementById("route-chart"), {
              type: "bar",
              data: {
                labels: routeData.labels,
                datasets: [{ label: "Cases", data: routeData.counts, backgroundColor: bg }]
              },
              options: {
                indexAxis: "y",
                scales: { x: { beginAtZero: true } },
                plugins: { legend: { display: false } }
              }
            });
          }

          if (metricData && document.getElementById("coverage-chart")) {
            new Chart(document.getElementById("coverage-chart"), {
              type: "bar",
              data: {
                labels: metricData.labels,
                datasets: [
                  { label: "Evaluated", data: metricData.successful, backgroundColor: "#2fa65a" },
                  { label: "Skipped", data: metricData.skipped, backgroundColor: "#d9dee6" },
                  { label: "Errors", data: metricData.errors, backgroundColor: "#aab4c3" }
                ]
              },
              options: {
                indexAxis: "y",
                scales: { x: { stacked: true }, y: { stacked: true } }
              }
            });
          }
        })();
      </script>
    {% endif %}
  </body>
</html>
